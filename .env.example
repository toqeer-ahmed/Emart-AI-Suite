# Copy this file to .env and fill in what you need. Every value here has a
# safe default if left unset - the suite runs in full demo mode with none
# of these set.

# --- LLM mode (Assistant + Listing Generator) ---
# Leave blank to run in free, offline "template mode".
# Set this to enable real Claude-generated replies/listings.
ANTHROPIC_API_KEY=

# --- Gateway auth ---
# Leave blank in development. Set this in production and configure
# E-Mart's backend to send it as the "X-EMart-AI-Key" header on every call.
EMART_AI_GATEWAY_KEY=

# --- CORS ---
# Comma-separated list of allowed origins, e.g. https://emart.example.com
EMART_AI_CORS_ORIGINS=*

# --- Storage paths (only change if you need custom volume mounts) ---
EMART_AI_DB_PATH=
EMART_AI_PHOTO_OUTPUT_DIR=
